# MongoDB
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="debt-tracker"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me"
# Must match the URL the app is served from. In production set this to your
# real domain, e.g. https://ledger.mdsalahuddin.dev
BETTER_AUTH_URL="http://localhost:3000"
# Optional: extra allowed origins, comma-separated (the app's own URL and
# localhost are already trusted).
# BETTER_AUTH_TRUSTED_ORIGINS="https://staging.example.com"

# Seed admin credentials (used by `npm run seed`)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Admin"

# Cloudflare R2 (S3-compatible object storage for the Files module)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# e.g. https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=""
R2_REGION="auto"
